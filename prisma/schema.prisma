datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  walletAddress String   @id @unique
  displayName   String
  role          String   @default("CUSTOMER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}
